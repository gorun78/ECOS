<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.chinacreator.gzcm.datanet.repository.DataSourceRepository">

    <resultMap id="dsMap" type="com.chinacreator.gzcm.runtime.core.datasource.entity.DataSourceEntity">
        <id property="datasourceId" column="datasource_id"/>
        <result property="datasourceName" column="datasource_name"/>
        <result property="datasourceType" column="datasource_type"/>
        <result property="orgId" column="org_id"/>
        <result property="nodeId" column="node_id"/>
        <result property="description" column="description"/>
        <result property="connectionConfig" column="connection_config"/>
        <result property="status" column="status"/>
        <result property="tags" column="tags"/>
        <result property="lastTestTime" column="last_test_time"/>
        <result property="lastTestResult" column="last_test_result"/>
        <result property="lastTestMessage" column="last_test_message"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="baseCols">
        datasource_id, datasource_name, datasource_type, org_id, node_id,
        description, connection_config, status, tags,
        last_test_time, last_test_result, last_test_message,
        create_by, create_time, update_by, update_time
    </sql>

    <insert id="insert">
        INSERT INTO td_datasource (<include refid="baseCols"/>)
        VALUES (#{datasourceId}, #{datasourceName}, #{datasourceType}, #{orgId}, #{nodeId},
                #{description}, #{connectionConfig}, #{status}, #{tags},
                #{lastTestTime}, #{lastTestResult}, #{lastTestMessage},
                #{createBy}, #{createTime}, #{updateBy}, #{updateTime})
    </insert>

    <update id="update">
        UPDATE td_datasource
        SET datasource_name = #{datasourceName},
            datasource_type = #{datasourceType},
            org_id = #{orgId},
            node_id = #{nodeId},
            description = #{description},
            connection_config = #{connectionConfig},
            status = #{status},
            tags = #{tags},
            last_test_time = #{lastTestTime},
            last_test_result = #{lastTestResult},
            last_test_message = #{lastTestMessage},
            update_by = #{updateBy},
            update_time = NOW()
        WHERE datasource_id = #{datasourceId}
    </update>

    <select id="findById" resultMap="dsMap">
        SELECT <include refid="baseCols"/> FROM td_datasource WHERE datasource_id = #{id}
    </select>

    <select id="findAll" resultMap="dsMap">
        SELECT <include refid="baseCols"/> FROM td_datasource ORDER BY create_time DESC
    </select>

    <delete id="deleteById">
        DELETE FROM td_datasource WHERE datasource_id = #{id}
    </delete>
</mapper>
